---
const title = "Lighthouse";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Operation Astro</title>
    <style>
      :root {
        color-scheme: dark;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #050913;
        color: #f4f7fb;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        overflow: hidden;
        background: #050913;
      }

      .lighthouse-space {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
        isolation: isolate;
        background: #050913;
      }

      .lighthouse-scene {
        position: absolute;
        inset: 0;
        z-index: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: 50% 50%;
        user-select: none;
      }

      .lighthouse-space::before {
        position: absolute;
        inset: 0;
        z-index: 1;
        background:
          radial-gradient(ellipse at 50% 52%, transparent 42%, rgba(2, 5, 12, 0.36) 100%),
          linear-gradient(180deg, rgba(3, 6, 13, 0.24), transparent 28%, rgba(3, 6, 13, 0.28));
        pointer-events: none;
        content: "";
      }

      .lighthouse-bar {
        position: absolute;
        top: 24px;
        right: 24px;
        left: 24px;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        pointer-events: none;
      }

      .lighthouse-title {
        margin: 0;
        color: rgba(255, 247, 220, 0.9);
        font-size: 14px;
        font-weight: 850;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-shadow: 0 2px 18px rgba(0, 0, 0, 0.52);
      }

      .return-link {
        display: inline-flex;
        min-height: 38px;
        align-items: center;
        justify-content: center;
        padding: 0 14px;
        border: 1px solid rgba(255, 231, 177, 0.2);
        border-radius: 8px;
        background: rgba(8, 12, 20, 0.32);
        color: rgba(255, 247, 220, 0.86);
        font-size: 13px;
        font-weight: 800;
        text-decoration: none;
        backdrop-filter: blur(10px);
        pointer-events: auto;
      }

      .return-link:hover,
      .return-link:focus-visible {
        border-color: rgba(255, 231, 177, 0.42);
        background: rgba(8, 12, 20, 0.46);
        outline: none;
      }

      .lighthouse-caption {
        position: absolute;
        right: 24px;
        bottom: 24px;
        z-index: 2;
        max-width: min(420px, calc(100vw - 48px));
        color: rgba(255, 244, 216, 0.72);
        font-size: 13px;
        font-weight: 650;
        line-height: 1.6;
        text-align: right;
        text-shadow: 0 2px 18px rgba(0, 0, 0, 0.62);
      }

      @media (max-width: 760px) {
        .lighthouse-bar {
          top: 16px;
          right: 16px;
          left: 16px;
        }

        .lighthouse-scene {
          object-position: 54% 50%;
        }

        .lighthouse-caption {
          right: 16px;
          bottom: 16px;
          left: 16px;
          max-width: none;
          text-align: left;
        }
      }
    </style>
  </head>
  <body>
    <main class="lighthouse-space" aria-label="Inside the lighthouse">
      <img
        class="lighthouse-scene"
        src="/camp/lighthouse_scene.png"
        alt=""
        width="1672"
        height="941"
        loading="eager"
        decoding="async"
        draggable="false"
      />
      <div class="lighthouse-bar">
        <h1 class="lighthouse-title">{title}</h1>
        <a class="return-link" href="/">Return Outside</a>
      </div>
    </main>
  </body>
</html>
