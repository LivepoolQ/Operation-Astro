---
const title = "Lighthouse";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Operation Astro</title>
    <style>
      :root {
        color-scheme: dark;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #050913;
        color: #f4f7fb;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        overflow: hidden;
        background: #050913;
      }

      .lighthouse-space {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
        isolation: isolate;
        background: #050913;
      }

      .scene-backdrop {
        position: absolute;
        inset: -24px;
        z-index: 0;
        overflow: hidden;
      }

      .scene-backdrop img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: blur(18px) brightness(0.58) saturate(1.06);
        transform: scale(1.04);
        user-select: none;
      }

      .scene-frame {
        position: absolute;
        top: 50%;
        left: 50%;
        z-index: 1;
        width: min(100vw, calc(100vh * 1672 / 941));
        height: min(100vh, calc(100vw * 941 / 1672));
        transform: translate(-50%, -50%);
        transform-origin: 50% 50%;
      }

      .lighthouse-scene {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        user-select: none;
      }

      .lighthouse-space::before {
        position: absolute;
        inset: 0;
        z-index: 2;
        background:
          radial-gradient(ellipse at 50% 52%, transparent 42%, rgba(2, 5, 12, 0.36) 100%),
          linear-gradient(180deg, rgba(3, 6, 13, 0.24), transparent 28%, rgba(3, 6, 13, 0.28));
        pointer-events: none;
        content: "";
      }

      .lighthouse-loader {
        --loader-progress: 0;
        position: fixed;
        inset: 0;
        z-index: 20;
        display: grid;
        place-items: center;
        background:
          radial-gradient(ellipse at 50% 38%, rgba(255, 222, 139, 0.13), transparent 30%),
          linear-gradient(180deg, #050913, #02050b);
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transition:
          opacity 420ms ease,
          visibility 420ms ease;
      }

      .lighthouse-loader.is-complete {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      .lighthouse-loader-panel {
        width: min(360px, calc(100vw - 48px));
      }

      .lighthouse-loader-title {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 12px;
        color: rgba(255, 247, 220, 0.86);
        font-size: 12px;
        font-weight: 850;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .lighthouse-loader-percent::before {
        content: attr(data-progress);
      }

      .lighthouse-loader-track {
        position: relative;
        height: 8px;
        overflow: hidden;
        border: 1px solid rgba(255, 231, 177, 0.2);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.06);
        box-shadow:
          0 0 26px rgba(255, 190, 91, 0.08),
          inset 0 1px 0 rgba(255, 255, 255, 0.05);
      }

      .lighthouse-loader-track::before {
        position: absolute;
        inset: 0;
        width: 100%;
        border-radius: inherit;
        background:
          linear-gradient(90deg, rgba(255, 171, 64, 0.86), rgba(255, 241, 172, 0.96));
        box-shadow: 0 0 22px rgba(255, 198, 96, 0.36);
        content: "";
        transform: scaleX(calc(var(--loader-progress) / 100));
        transform-origin: left center;
        transition: transform 120ms linear;
      }

      .lighthouse-loader-note {
        margin: 11px 0 0;
        color: rgba(232, 238, 249, 0.48);
        font-size: 12px;
        font-weight: 650;
        letter-spacing: 0.02em;
      }

      .lighthouse-item {
        position: absolute;
        z-index: 2;
        display: block;
        padding: 0;
        border: 0;
        background: transparent;
        color: inherit;
        line-height: 0;
        cursor: pointer;
        appearance: none;
      }

      .lighthouse-item:focus-visible {
        outline: none;
      }

      .lighthouse-cat {
        left: 59.7%;
        top: 3.5%;
        width: 4.2%;
        opacity: 0.92;
        filter: drop-shadow(0 0 10px rgba(255, 228, 148, 0.12));
        transform: rotate(-4deg);
        transform-origin: 50% 70%;
      }

      .lighthouse-cat img {
        display: block;
        width: 50%;
        height: auto;
        pointer-events: none;
        user-select: none;
      }

      .lighthouse-cat.is-hidden {
        opacity: 0;
        pointer-events: none;
        visibility: hidden;
      }

      .lantern-glow {
        position: absolute;
        left: 16.3%;
        top: 66%;
        z-index: 2;
        width: 25.7%;
        height: 35.1%;
        border-radius: 50%;
        background:
          radial-gradient(ellipse at 39% 35%, rgba(255, 237, 148, 0.76), transparent 14%),
          radial-gradient(ellipse at 42% 42%, rgba(255, 151, 42, 0.36), transparent 42%),
          radial-gradient(ellipse at 52% 62%, rgba(255, 189, 78, 0.22), transparent 76%);
        filter: blur(12px);
        mix-blend-mode: screen;
        opacity: 0.82;
        pointer-events: none;
        transform: translate(-50%, -50%);
        animation: lantern-firelight 3.2s ease-in-out infinite;
      }

      .lantern-glow::after {
        position: absolute;
        left: 22%;
        top: 54%;
        width: 136%;
        height: 76%;
        border-radius: 50%;
        background: radial-gradient(ellipse at 50% 50%, rgba(255, 158, 48, 0.28), transparent 70%);
        filter: blur(20px);
        opacity: 0.86;
        transform: rotate(-7deg);
        content: "";
      }

      .lighthouse-bar {
        position: absolute;
        top: 24px;
        right: 24px;
        left: 24px;
        z-index: 3;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        pointer-events: none;
      }

      .lighthouse-title {
        margin: 0;
        color: rgba(255, 247, 220, 0.9);
        font-size: 14px;
        font-weight: 850;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-shadow: 0 2px 18px rgba(0, 0, 0, 0.52);
      }

      .return-link {
        display: inline-flex;
        min-height: 38px;
        align-items: center;
        justify-content: center;
        padding: 0 14px;
        border: 1px solid rgba(255, 231, 177, 0.2);
        border-radius: 8px;
        background: rgba(8, 12, 20, 0.32);
        color: rgba(255, 247, 220, 0.86);
        font-size: 13px;
        font-weight: 800;
        text-decoration: none;
        backdrop-filter: blur(10px);
        pointer-events: auto;
      }

      .return-link:hover,
      .return-link:focus-visible {
        border-color: rgba(255, 231, 177, 0.42);
        background: rgba(8, 12, 20, 0.46);
        outline: none;
      }

      .lighthouse-caption {
        position: absolute;
        right: 24px;
        bottom: 24px;
        z-index: 3;
        max-width: min(420px, calc(100vw - 48px));
        color: rgba(255, 244, 216, 0.72);
        font-size: 13px;
        font-weight: 650;
        line-height: 1.6;
        text-align: right;
        text-shadow: 0 2px 18px rgba(0, 0, 0, 0.62);
      }

      .lighthouse-dialog {
        position: fixed;
        right: 24px;
        bottom: 24px;
        left: 24px;
        z-index: 30;
        display: flex;
        justify-content: center;
        pointer-events: none;
      }

      .lighthouse-dialog[hidden] {
        display: none;
      }

      .lighthouse-dialog-panel {
        position: relative;
        width: min(560px, 100%);
        padding: 18px 48px 18px 20px;
        border: 1px solid rgba(255, 231, 177, 0.22);
        border-radius: 8px;
        background:
          linear-gradient(180deg, rgba(20, 18, 15, 0.96), rgba(8, 7, 12, 0.98));
        box-shadow:
          0 20px 70px rgba(0, 0, 0, 0.42),
          inset 0 1px 0 rgba(255, 255, 255, 0.06);
        pointer-events: auto;
      }

      .lighthouse-dialog-line {
        min-height: 24px;
        margin: 0;
        color: rgba(255, 247, 220, 0.92);
        font-size: 15px;
        font-weight: 650;
        line-height: 1.65;
      }

      .lighthouse-dialog-close {
        position: absolute;
        top: 12px;
        right: 12px;
        display: grid;
        width: 30px;
        height: 30px;
        place-items: center;
        border: 1px solid rgba(255, 231, 177, 0.16);
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.04);
        color: rgba(255, 247, 220, 0.76);
        cursor: pointer;
      }

      .lighthouse-dialog-close:hover,
      .lighthouse-dialog-close:focus-visible {
        border-color: rgba(255, 231, 177, 0.38);
        outline: none;
      }

      @keyframes lantern-firelight {
        0%,
        100% {
          opacity: 0.58;
          transform: translate(-50%, -50%) scale(0.9, 0.88);
        }

        24% {
          opacity: 0.76;
          transform: translate(-50%, -50%) scale(1.02, 0.96);
        }

        43% {
          opacity: 1;
          transform: translate(-50%, -50%) scale(1.18, 1.12);
        }

        62% {
          opacity: 0.84;
          transform: translate(-50%, -50%) scale(1.07, 1.03);
        }

        80% {
          opacity: 0.62;
          transform: translate(-50%, -50%) scale(0.94, 0.9);
        }
      }

      @media (max-width: 760px) {
        .lighthouse-bar {
          top: 16px;
          right: 16px;
          left: 16px;
        }

        .lighthouse-caption {
          right: 16px;
          bottom: 16px;
          left: 16px;
          max-width: none;
          text-align: left;
        }
      }
    </style>
  </head>
  <body>
    <div class="lighthouse-loader" aria-hidden="true">
      <div class="lighthouse-loader-panel">
        <div class="lighthouse-loader-title">
          <span>Entering Lighthouse</span>
          <span class="lighthouse-loader-percent" data-loader-percent data-progress="00%"></span>
        </div>
        <div class="lighthouse-loader-track"></div>
        <p class="lighthouse-loader-note">Climbing the spiral stairs</p>
      </div>
    </div>
    <main class="lighthouse-space" aria-label="Inside the lighthouse">
      <div class="scene-backdrop" aria-hidden="true">
        <img
          data-preload-src="/camp/lighthouse_1stfloor.png"
          alt=""
          width="1672"
          height="941"
          loading="eager"
          decoding="async"
          draggable="false"
        />
      </div>
      <div class="scene-frame">
        <img
          class="lighthouse-scene"
          data-preload-src="/camp/lighthouse_1stfloor.png"
          alt=""
          width="1672"
          height="941"
          loading="eager"
          decoding="async"
          draggable="false"
        />
        <div class="lantern-glow" aria-hidden="true"></div>
        <button
          class="lighthouse-item lighthouse-cat"
          type="button"
          data-lighthouse-item="cat"
          data-lighthouse-label="Cat"
          aria-label="Interact with the cat"
        >
          <img data-preload-src="/camp/cat_near.gif" alt="" width="568" height="586" loading="eager" decoding="async" draggable="false" />
        </button>
      </div>
      <div class="lighthouse-bar">
        <h1 class="lighthouse-title">{title}</h1>
        <a class="return-link" href="/">Return Outside</a>
      </div>
    </main>
    <div class="lighthouse-dialog" data-lighthouse-dialog hidden role="status" aria-live="polite">
      <div class="lighthouse-dialog-panel">
        <button class="lighthouse-dialog-close" type="button" data-lighthouse-dialog-close aria-label="Close dialogue">×</button>
        <p class="lighthouse-dialog-line" data-lighthouse-dialog-line></p>
      </div>
    </div>
    <script>
      const loader = document.querySelector(".lighthouse-loader");
      const loaderPercent = document.querySelector("[data-loader-percent]");
      const preloadImages = Array.from(document.querySelectorAll("[data-preload-src]"));
      const lighthouseItems = Array.from(document.querySelectorAll("[data-lighthouse-item]"));
      const lighthouseDialog = document.querySelector("[data-lighthouse-dialog]");
      const lighthouseDialogClose = document.querySelector("[data-lighthouse-dialog-close]");
      const lighthouseDialogLine = document.querySelector("[data-lighthouse-dialog-line]");
      const lighthouseCat = document.querySelector("[data-lighthouse-item='cat']");
      const LIGHTHOUSE_CAT_RESPAWN_MS = 60 * 1000;
      let activeLighthouseDialogueId = "";
      let lighthouseCatRespawnTimer = 0;

      const setLoaderProgress = (progress) => {
        const value = Math.max(0, Math.min(100, Math.round(progress)));
        loader?.style.setProperty("--loader-progress", String(value));
        loaderPercent?.setAttribute("data-progress", `${String(value).padStart(2, "0")}%`);
      };

      const finishLoader = () => {
        setLoaderProgress(100);
        window.setTimeout(() => {
          loader?.classList.add("is-complete");
        }, 180);
      };

      const applyBlobToImage = async (element, blob) => {
        element.src = URL.createObjectURL(blob);
        await element.decode?.().catch(() => {});
      };

      const preloadAsset = async ({ element, response, total }, onProgress) => {
        if (!response.body || !total) {
          const blob = await response.blob();
          await applyBlobToImage(element, blob);
          onProgress(total || blob.size || 1, total || blob.size || 1);
          return;
        }

        const reader = response.body.getReader();
        const chunks = [];
        let loaded = 0;

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          chunks.push(value);
          loaded += value.byteLength;
          onProgress(loaded, total);
        }

        const blob = new Blob(chunks, {
          type: response.headers.get("content-type") || "application/octet-stream",
        });
        await applyBlobToImage(element, blob);
      };

      const preloadLighthouseAssets = async () => {
        if (!preloadImages.length) {
          finishLoader();
          return;
        }

        const loadedBytes = new Map();
        const fallbackStep = 100 / preloadImages.length;

        try {
          const assets = await Promise.all(
            preloadImages.map(async (element) => {
              const url = element.dataset.preloadSrc;
              const response = await fetch(url, { cache: "force-cache" });
              if (!response.ok) throw new Error(`Could not load ${url}`);
              return {
                element,
                response,
                total: Number(response.headers.get("content-length")) || 0,
              };
            }),
          );
          const knownGrandTotal = assets.reduce((sum, asset) => sum + asset.total, 0);

          await Promise.all(
            assets.map((asset, index) =>
              preloadAsset(asset, (loaded) => {
                loadedBytes.set(index, loaded);
                const knownLoaded = Array.from(loadedBytes.values()).reduce((sum, value) => sum + value, 0);
                const fallbackProgress = loadedBytes.size * fallbackStep;
                setLoaderProgress(knownGrandTotal > 0 ? (knownLoaded / knownGrandTotal) * 100 : fallbackProgress);
              }),
            ),
          );
          finishLoader();
        } catch {
          preloadImages.forEach((element) => {
            if (element.dataset.preloadSrc && !element.getAttribute("src")) {
              element.src = element.dataset.preloadSrc;
            }
          });
          finishLoader();
        }
      };

      const closeLighthouseDialogue = () => {
        if (activeLighthouseDialogueId === "cat" && lighthouseCat instanceof HTMLElement) {
          lighthouseCat.classList.add("is-hidden");
          window.clearTimeout(lighthouseCatRespawnTimer);
          lighthouseCatRespawnTimer = window.setTimeout(() => {
            lighthouseCat.classList.remove("is-hidden");
            lighthouseCatRespawnTimer = 0;
          }, LIGHTHOUSE_CAT_RESPAWN_MS);
        }

        activeLighthouseDialogueId = "";
        if (lighthouseDialog) lighthouseDialog.hidden = true;
      };

      const showLighthouseDialogue = (line, id = "") => {
        if (!lighthouseDialog || !lighthouseDialogLine || !line) return;
        activeLighthouseDialogueId = id;
        lighthouseDialogLine.textContent = line;
        lighthouseDialog.hidden = false;
      };

      lighthouseItems.forEach((item) => {
        item.addEventListener("click", () => {
          window.dispatchEvent(
            new CustomEvent("lighthouse:click", {
              detail: {
                id: item.dataset.lighthouseItem || "",
                label: item.dataset.lighthouseLabel || "",
                element: item,
              },
            }),
          );
        });
      });

      window.addEventListener("lighthouse:click", (event) => {
        const id = event.detail?.id;
        if (id === "cat") {
          showLighthouseDialogue("It's the black cat I saw in the forest. What is he doing here...", id);
        }
      });

      lighthouseDialogClose?.addEventListener("click", closeLighthouseDialogue);
      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeLighthouseDialogue();
        }
      });

      setLoaderProgress(0);
      preloadLighthouseAssets();
    </script>
  </body>
</html>
