---
const title = "Lighthouse";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Operation Astro</title>
    <style>
      :root {
        color-scheme: dark;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #050913;
        color: #f4f7fb;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        overflow: hidden;
        background: #050913;
      }

      .lighthouse-space {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
        isolation: isolate;
        background: #050913;
      }

      .lighthouse-scene {
        position: absolute;
        inset: 0;
        z-index: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: 50% 50%;
        user-select: none;
      }

      .lighthouse-space::before {
        position: absolute;
        inset: 0;
        z-index: 1;
        background:
          radial-gradient(ellipse at 50% 52%, transparent 42%, rgba(2, 5, 12, 0.36) 100%),
          linear-gradient(180deg, rgba(3, 6, 13, 0.24), transparent 28%, rgba(3, 6, 13, 0.28));
        pointer-events: none;
        content: "";
      }

      .lighthouse-item {
        position: absolute;
        z-index: 2;
        display: block;
        padding: 0;
        border: 0;
        background: transparent;
        color: inherit;
        line-height: 0;
        cursor: pointer;
        appearance: none;
      }

      .lighthouse-item:focus-visible {
        outline: none;
      }

      .lighthouse-cat {
        left: 59.7%;
        top: 2%;
        width: clamp(34px, 4.2vw, 72px);
        opacity: 0.92;
        filter: drop-shadow(0 0 10px rgba(255, 228, 148, 0.12));
        transform: rotate(-4deg);
        transform-origin: 50% 70%;
      }

      .lighthouse-cat img {
        display: block;
        width: 50%;
        height: auto;
        pointer-events: none;
        user-select: none;
      }

      .lantern-glow {
        position: absolute;
        left: 16.3%;
        top: 66%;
        z-index: 2;
        width: clamp(180px, 27vw, 430px);
        height: clamp(140px, 21vw, 330px);
        border-radius: 50%;
        background:
          radial-gradient(ellipse at 39% 35%, rgba(255, 237, 148, 0.76), transparent 14%),
          radial-gradient(ellipse at 42% 42%, rgba(255, 151, 42, 0.36), transparent 42%),
          radial-gradient(ellipse at 52% 62%, rgba(255, 189, 78, 0.22), transparent 76%);
        filter: blur(12px);
        mix-blend-mode: screen;
        opacity: 0.82;
        pointer-events: none;
        transform: translate(-50%, -50%);
        animation: lantern-firelight 3.2s ease-in-out infinite;
      }

      .lantern-glow::after {
        position: absolute;
        left: 22%;
        top: 54%;
        width: 136%;
        height: 76%;
        border-radius: 50%;
        background: radial-gradient(ellipse at 50% 50%, rgba(255, 158, 48, 0.28), transparent 70%);
        filter: blur(20px);
        opacity: 0.86;
        transform: rotate(-7deg);
        content: "";
      }

      .lighthouse-bar {
        position: absolute;
        top: 24px;
        right: 24px;
        left: 24px;
        z-index: 3;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        pointer-events: none;
      }

      .lighthouse-title {
        margin: 0;
        color: rgba(255, 247, 220, 0.9);
        font-size: 14px;
        font-weight: 850;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-shadow: 0 2px 18px rgba(0, 0, 0, 0.52);
      }

      .return-link {
        display: inline-flex;
        min-height: 38px;
        align-items: center;
        justify-content: center;
        padding: 0 14px;
        border: 1px solid rgba(255, 231, 177, 0.2);
        border-radius: 8px;
        background: rgba(8, 12, 20, 0.32);
        color: rgba(255, 247, 220, 0.86);
        font-size: 13px;
        font-weight: 800;
        text-decoration: none;
        backdrop-filter: blur(10px);
        pointer-events: auto;
      }

      .return-link:hover,
      .return-link:focus-visible {
        border-color: rgba(255, 231, 177, 0.42);
        background: rgba(8, 12, 20, 0.46);
        outline: none;
      }

      .lighthouse-caption {
        position: absolute;
        right: 24px;
        bottom: 24px;
        z-index: 3;
        max-width: min(420px, calc(100vw - 48px));
        color: rgba(255, 244, 216, 0.72);
        font-size: 13px;
        font-weight: 650;
        line-height: 1.6;
        text-align: right;
        text-shadow: 0 2px 18px rgba(0, 0, 0, 0.62);
      }

      @keyframes lantern-firelight {
        0%,
        100% {
          opacity: 0.58;
          transform: translate(-50%, -50%) scale(0.9, 0.88);
        }

        24% {
          opacity: 0.76;
          transform: translate(-50%, -50%) scale(1.02, 0.96);
        }

        43% {
          opacity: 1;
          transform: translate(-50%, -50%) scale(1.18, 1.12);
        }

        62% {
          opacity: 0.84;
          transform: translate(-50%, -50%) scale(1.07, 1.03);
        }

        80% {
          opacity: 0.62;
          transform: translate(-50%, -50%) scale(0.94, 0.9);
        }
      }

      @media (max-width: 760px) {
        .lighthouse-bar {
          top: 16px;
          right: 16px;
          left: 16px;
        }

        .lighthouse-scene {
          object-position: 54% 50%;
        }

        .lantern-glow {
          left: 9.6%;
          top: 62%;
          width: clamp(160px, 42vw, 260px);
          height: clamp(120px, 34vw, 210px);
        }

        .lighthouse-cat {
          left: 58%;
          top: 15%;
          width: clamp(28px, 9vw, 48px);
        }

        .lighthouse-caption {
          right: 16px;
          bottom: 16px;
          left: 16px;
          max-width: none;
          text-align: left;
        }
      }
    </style>
  </head>
  <body>
    <main class="lighthouse-space" aria-label="Inside the lighthouse">
      <img
        class="lighthouse-scene"
        src="/camp/lighthouse_scene.png"
        alt=""
        width="1672"
        height="941"
        loading="eager"
        decoding="async"
        draggable="false"
      />
      <div class="lantern-glow" aria-hidden="true"></div>
      <button
        class="lighthouse-item lighthouse-cat"
        type="button"
        data-lighthouse-item="cat"
        data-lighthouse-label="Cat"
        aria-label="Interact with the cat"
      >
        <img src="/camp/cat.png" alt="" width="568" height="586" loading="eager" decoding="async" draggable="false" />
      </button>
      <div class="lighthouse-bar">
        <h1 class="lighthouse-title">{title}</h1>
        <a class="return-link" href="/">Return Outside</a>
      </div>
    </main>
    <script>
      const lighthouseItems = Array.from(document.querySelectorAll("[data-lighthouse-item]"));

      lighthouseItems.forEach((item) => {
        item.addEventListener("click", () => {
          window.dispatchEvent(
            new CustomEvent("lighthouse:click", {
              detail: {
                id: item.dataset.lighthouseItem || "",
                label: item.dataset.lighthouseLabel || "",
                element: item,
              },
            }),
          );
        });
      });
    </script>
  </body>
</html>
