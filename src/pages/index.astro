---
const name = "Ziqian Zou";

const planets = [
  {
    id: "games",
    title: "Games Planet",
    orbit: "Night Run",
    description: "Games in progress, finished stories, design notes, and the moments worth one more round.",
    x: 24,
    y: 38,
    size: 108,
    tone: "amber",
  },
  {
    id: "travel",
    title: "Travel Planet",
    orbit: "Horizon Log",
    description: "Cities, routes, photos, and small fragments from places that still glow in memory.",
    x: 70,
    y: 30,
    size: 92,
    tone: "cyan",
  },
  {
    id: "projects",
    title: "Projects Planet",
    orbit: "Builder Track",
    description: "Code, papers, tools, experiments, and the versions that survived careful iteration.",
    x: 56,
    y: 50,
    size: 132,
    tone: "violet",
  },
];
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{name}</title>
    <meta name="description" content={`${name} personal website`} />
    <style>
      :root {
        color-scheme: dark;
        --ink: #f4f7fb;
        --muted: rgba(232, 238, 249, 0.68);
        --quiet: rgba(232, 238, 249, 0.44);
        --panel: rgba(8, 14, 30, 0.66);
        --line: rgba(205, 220, 255, 0.18);
        --shadow: rgba(0, 0, 0, 0.42);
      }

      * {
        box-sizing: border-box;
      }

      html {
        min-height: 100%;
        background: #030712;
      }

      body {
        min-height: 240vh;
        margin: 0;
        overflow-x: hidden;
        color: var(--ink);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei",
          sans-serif;
        background:
          radial-gradient(circle at 50% 112%, rgba(52, 123, 184, 0.22), transparent 31rem),
          radial-gradient(circle at 28% 14%, rgba(86, 157, 199, 0.18), transparent 22rem),
          radial-gradient(circle at 76% 18%, rgba(213, 109, 141, 0.15), transparent 19rem),
          linear-gradient(180deg, #030814 0%, #071225 48%, #050811 100%);
      }

      body::before,
      body::after {
        position: fixed;
        inset: 0;
        z-index: -3;
        pointer-events: none;
        content: "";
      }

      body::before {
        background-image:
          radial-gradient(circle at 12% 18%, rgba(255, 255, 255, 0.92) 0 1px, transparent 1.5px),
          radial-gradient(circle at 38% 72%, rgba(142, 203, 255, 0.7) 0 1px, transparent 1.6px),
          radial-gradient(circle at 76% 34%, rgba(255, 238, 201, 0.82) 0 1px, transparent 1.4px),
          radial-gradient(circle at 20% 86%, rgba(255, 255, 255, 0.52) 0 0.7px, transparent 1.2px),
          radial-gradient(circle at 92% 64%, rgba(175, 206, 255, 0.5) 0 0.8px, transparent 1.3px),
          radial-gradient(ellipse at 68% 24%, rgba(169, 199, 236, 0.12), transparent 18rem),
          radial-gradient(ellipse at 21% 42%, rgba(255, 206, 145, 0.08), transparent 14rem);
        background-position:
          0 0,
          30px 80px,
          110px 40px,
          48px 120px,
          160px 90px,
          0 0,
          0 0;
        background-size:
          190px 190px,
          260px 260px,
          330px 330px,
          120px 120px,
          460px 460px,
          100% 100%,
          100% 100%;
        opacity: 0.86;
      }

      body::after {
        z-index: -2;
        background:
          linear-gradient(rgba(157, 187, 231, 0.055) 1px, transparent 1px),
          linear-gradient(90deg, rgba(157, 187, 231, 0.045) 1px, transparent 1px);
        background-size: 76px 76px;
        mask-image: radial-gradient(ellipse at 50% 66%, black 0 41%, transparent 75%);
        opacity: 0.8;
        transform: perspective(760px) rotateX(62deg) translateY(18vh);
        transform-origin: center bottom;
      }

      a {
        color: inherit;
      }

      .shell {
        position: relative;
        display: grid;
        min-height: 240vh;
        grid-template-rows: 1fr;
        padding: 0;
      }

      .footer {
        position: fixed;
        right: clamp(16px, 2vw, 28px);
        bottom: clamp(14px, 2vw, 24px);
        left: clamp(16px, 2vw, 28px);
        z-index: 8;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        color: var(--quiet);
        font-size: 13px;
      }

      .sky {
        position: fixed;
        inset: 0;
        z-index: 0;
        display: grid;
        min-height: 100vh;
        overflow: hidden;
        place-items: center;
        padding: 0;
      }

      .dome {
        --camp-lift: 0px;
        --forest-far-lift: 0px;
        --planet-depth: 1;
        --ridge-far-lift: 0px;
        --ridge-middle-lift: 0px;
        --scene-start-offset: 8vh;
        position: relative;
        width: 100%;
        min-height: 100vh;
        overflow: hidden;
        border-bottom: 1px solid rgba(221, 232, 255, 0.18);
        border-radius: 0;
        background:
          radial-gradient(ellipse at 50% 100%, rgba(86, 170, 224, 0.19), transparent 38%),
          radial-gradient(ellipse at 50% 48%, rgba(255, 255, 255, 0.08), transparent 58%);
        box-shadow:
          inset 0 -40px 90px rgba(32, 101, 157, 0.17),
          0 36px 80px rgba(0, 0, 0, 0.24);
      }

      .dome::after {
        position: absolute;
        top: 0;
        right: 0;
        bottom: 24%;
        left: 0;
        z-index: 1;
        background:
          radial-gradient(circle at 16% 22%, rgba(255, 255, 255, 0.82) 0 1px, transparent 1.5px),
          radial-gradient(circle at 64% 18%, rgba(185, 215, 255, 0.74) 0 1px, transparent 1.6px),
          radial-gradient(circle at 83% 42%, rgba(255, 230, 184, 0.66) 0 0.9px, transparent 1.5px),
          radial-gradient(circle at 42% 54%, rgba(255, 255, 255, 0.42) 0 0.7px, transparent 1.3px),
          radial-gradient(ellipse at 71% 27%, rgba(104, 154, 218, 0.16), transparent 12rem),
          radial-gradient(ellipse at 27% 34%, rgba(217, 136, 162, 0.1), transparent 10rem);
        background-position:
          0 0,
          70px 40px,
          20px 100px,
          130px 20px,
          0 0,
          0 0;
        background-size:
          150px 150px,
          230px 230px,
          310px 310px,
          90px 90px,
          100% 100%,
          100% 100%;
        opacity: 0.95;
        pointer-events: none;
        content: "";
      }

      .intro {
        position: absolute;
        top: clamp(34px, 8vh, 76px);
        left: clamp(22px, 6vw, 78px);
        z-index: 6;
        max-width: min(410px, calc(100% - 44px));
      }

      h1 {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: baseline;
        max-width: 100%;
        margin: 0;
        color: #a9c7ec;
        font-size: 16px;
        font-weight: 500;
        line-height: 1.4;
        letter-spacing: 0;
      }

      .identity-name {
        color: var(--ink);
        font-weight: 800;
      }

      .orbit-field {
        position: absolute;
        top: 50%;
        left: 50%;
        z-index: 2;
        width: 136%;
        height: 136%;
        transform: translate(-50%, -50%) scale(var(--planet-depth));
        transform-origin: 50% 50%;
        transition: transform 80ms linear;
      }

      .planet {
        --planet-size: 96px;
        --planet-a: #f4b456;
        --planet-b: #8b4720;
        --planet-c: #fff2c8;
        position: absolute;
        left: calc(var(--x) * 1%);
        top: calc(var(--y) * 1%);
        width: var(--planet-size);
        height: var(--planet-size);
        padding: 0;
        border: 0;
        border-radius: 50%;
        color: inherit;
        cursor: pointer;
        transform: translate(-50%, -50%);
        background:
          radial-gradient(circle at 32% 24%, var(--planet-c) 0 7%, transparent 8%),
          radial-gradient(circle at 35% 31%, var(--planet-a) 0 18%, transparent 36%),
          radial-gradient(circle at 62% 68%, rgba(0, 0, 0, 0.35), transparent 42%),
          radial-gradient(circle at 50% 50%, var(--planet-a), var(--planet-b) 72%);
        box-shadow:
          inset -18px -20px 24px rgba(0, 0, 0, 0.34),
          inset 10px 8px 18px rgba(255, 255, 255, 0.18),
          0 0 0 1px rgba(255, 255, 255, 0.13),
          0 0 46px color-mix(in srgb, var(--planet-a), transparent 34%);
        transition:
          transform 180ms ease,
          filter 180ms ease,
          box-shadow 180ms ease;
      }

      .planet::after {
        position: absolute;
        inset: -8px;
        border-radius: inherit;
        background: radial-gradient(circle, color-mix(in srgb, var(--planet-a), transparent 52%), transparent 66%);
        filter: blur(14px);
        opacity: 0.72;
        z-index: -1;
        content: "";
      }

      .planet:hover,
      .planet:focus-visible,
      .planet.is-active {
        filter: saturate(1.22) brightness(1.1);
        outline: none;
        transform: translate(-50%, -50%) scale(1.08);
      }

      .planet[data-tone="cyan"] {
        --planet-a: #77d9ee;
        --planet-b: #1c5b78;
        --planet-c: #e9ffff;
      }

      .planet[data-tone="violet"] {
        --planet-a: #a996ff;
        --planet-b: #493a8c;
        --planet-c: #fff4ff;
      }

      .planet-label {
        position: absolute;
        top: calc(100% + 13px);
        left: 50%;
        width: max-content;
        max-width: 150px;
        color: rgba(244, 247, 251, 0.88);
        font-size: 14px;
        font-weight: 650;
        opacity: 0;
        pointer-events: none;
        text-align: center;
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8);
        transform: translateX(-50%);
        transition: opacity 160ms ease, transform 160ms ease;
      }

      .planet:hover .planet-label,
      .planet:focus-visible .planet-label,
      .planet.is-active .planet-label {
        opacity: 1;
        transform: translateX(-50%) translateY(2px);
      }

      .info-card {
        position: absolute;
        left: 0;
        top: 0;
        z-index: 7;
        width: min(292px, calc(100% - 36px));
        padding: 16px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent 42%),
          var(--panel);
        box-shadow: 0 18px 44px var(--shadow);
        backdrop-filter: blur(18px);
        opacity: 0;
        pointer-events: none;
        transform: translate3d(0, 10px, 0) scale(0.98);
        transition:
          opacity 150ms ease,
          transform 150ms ease;
      }

      .info-card.is-visible {
        opacity: 1;
        transform: translate3d(0, 0, 0) scale(1);
      }

      .info-card p {
        margin: 0;
      }

      .info-kicker {
        color: #a9c7ec;
        font-size: 12px;
        font-weight: 600;
        line-height: 1.4;
      }

      .info-title {
        margin: 8px 0;
        font-size: 16px;
        font-weight: 800;
        line-height: 1.35;
      }

      .info-desc {
        color: var(--muted);
        font-size: 13px;
        line-height: 1.65;
      }

      .horizon {
        position: absolute;
        right: 0;
        bottom: -78vh;
        left: 0;
        z-index: 4;
        height: 76vh;
        border-radius: 0;
        background:
          linear-gradient(180deg, #18243a 0%, #111b2c 44%, #050913 100%);
        pointer-events: none;
        transform: translate3d(0, calc(var(--scene-start-offset) - var(--camp-lift)), 0);
        transition: transform 80ms linear;
      }

      .landscape-layers {
        position: absolute;
        right: 0;
        bottom: 0;
        left: 0;
        z-index: 3;
        height: 100vh;
        overflow: hidden;
        pointer-events: none;
        transform: translate3d(0, var(--scene-start-offset), 0);
        transition: transform 80ms linear;
      }

      .landscape-layer {
        position: absolute;
        right: 0;
        left: 0;
        line-height: 0;
      }

      .landscape-layer svg,
      .ground-forest svg {
        display: block;
        width: 100%;
        height: 100%;
        overflow: visible;
      }

      .ridge-far {
        bottom: -20vh;
        height: 90vh;
        opacity: 1;
        transform: translate3d(0, calc(var(--ridge-far-lift) * -1), 0);
        transition: transform 80ms linear;
      }

      .ridge-lighthouse {
        position: absolute;
        left: 27%;
        bottom: 47.3%;
        z-index: 2;
        width: clamp(44px, 6.6vw, 108px);
        height: auto;
        opacity: 0.78;
        filter: drop-shadow(0 0 14px rgba(255, 236, 188, 0.26));
        transform: translateX(-50%);
        transform-origin: 50% 62%;
        user-select: none;
      }

      .ridge-lighthouse::before {
        position: absolute;
        inset: -13%;
        z-index: 0;
        border-radius: 50%;
        background:
          radial-gradient(circle at 50% 48%, rgba(255, 244, 191, 0.16), transparent 38%),
          radial-gradient(circle at 50% 50%, rgba(255, 231, 154, 0.07), transparent 68%);
        filter: blur(7px);
        opacity: 0.38;
        animation: lighthouse-glow 7.5s ease-in-out infinite;
        content: "";
      }

      .ridge-lighthouse .camp-visual {
        filter: drop-shadow(0 0 9px rgba(255, 243, 192, 0.13));
      }

      .ridge-middle {
        bottom: -35vh;
        height: 71vh;
        opacity: 0.9;
        transform: translate3d(0, calc(var(--ridge-middle-lift) * -1), 0);
        transition: transform 80ms linear;
      }

      .forest-far {
        bottom: -30vh;
        height: 31vh;
        opacity: 0.92;
        transform: translate3d(0, calc(var(--forest-far-lift) * -1), 0);
        transition: transform 80ms linear;
      }

      .ground-forest {
        position: absolute;
        left: 50%;
        bottom: -5vh;
        z-index: 5;
        width: 100vw;
        height: clamp(132px, 16vw, 220px);
        pointer-events: none;
        transform: translate3d(-50%, calc(var(--scene-start-offset) - var(--camp-lift)), 0);
        transition: transform 80ms linear;
      }

      .fire-reflection {
        position: absolute;
        left: calc(50% + clamp(48px, 6.5vw, 82px));
        bottom: calc(-58vh + var(--camp-lift));
        z-index: 5;
        width: clamp(250px, 33vw, 420px);
        height: clamp(96px, 12vw, 156px);
        border-radius: 50%;
        background:
          radial-gradient(ellipse at 50% 42%, rgba(255, 151, 55, 0.34), transparent 30%),
          radial-gradient(ellipse at 50% 58%, rgba(255, 209, 111, 0.2), transparent 62%);
        filter: blur(12px);
        opacity: 0.72;
        pointer-events: none;
        transform: translate3d(-50%, var(--scene-start-offset), 0);
      }

      .camp-scene {
        position: absolute;
        left: 50%;
        bottom: -44vh;
        z-index: 6;
        width: clamp(360px, 48vw, 610px);
        height: clamp(170px, 22vw, 276px);
        pointer-events: auto;
        transform: translate3d(-50%, calc(var(--scene-start-offset) - var(--camp-lift)), 0);
        transition: transform 80ms linear;
      }

      .camp-item {
        position: absolute;
        display: block;
        height: auto;
        padding: 0;
        border: 0;
        background: transparent;
        color: inherit;
        line-height: 0;
        cursor: pointer;
        pointer-events: auto;
        touch-action: manipulation;
        user-select: none;
        transform-origin: 50% 78%;
        transition:
          transform 180ms ease,
          opacity 180ms ease,
          filter 180ms ease;
        appearance: none;
      }

      .camp-visual {
        position: relative;
        z-index: 2;
        display: block;
        width: 100%;
        height: auto;
        object-fit: contain;
        pointer-events: none;
        user-select: none;
      }

      .camp-item:focus-visible {
        outline: none;
      }

      .camp-car {
        left: 0;
        bottom: 16%;
        z-index: 1;
        width: 39%;
        --fire-lit-filter: brightness(0.84) saturate(0.92);
        filter: var(--fire-lit-filter);
      }

      .cast-shadow {
        position: absolute;
        z-index: 1;
        border-radius: 50%;
        background: radial-gradient(ellipse at 50% 50%, rgba(0, 0, 0, 0.68), transparent 70%);
        filter: blur(8px);
        opacity: 0.72;
        pointer-events: none;
        transform-origin: 50% 50%;
      }

      .car-shadow {
        left: -16%;
        bottom: -6%;
        width: 128%;
        height: 80%;
        transform: rotate(8deg) skewX(-26deg);
        opacity: 0.64;
      }

      .people-shadow {
        left: -31%;
        bottom: 18%;
        width: 108%;
        height: 28%;
        transform: rotate(10deg) skewX(-28deg);
      }

      .dog-shadow {
        left: 62%;
        bottom: 18%;
        width: 106%;
        height: 25%;
        transform: rotate(-12deg) skewX(-28deg);
      }

      .people-reflection {
        position: absolute;
        left: 43%;
        top: 31%;
        z-index: 3;
        width: 20%;
        height: 34%;
        border-radius: 48% 52% 56% 44%;
        background:
          radial-gradient(ellipse at 45% 24%, rgba(17, 19, 25, 0.32), transparent 24%),
          linear-gradient(165deg, transparent 0 24%, rgba(15, 18, 26, 0.32) 25% 62%, transparent 63%);
        filter: blur(3px);
        mix-blend-mode: multiply;
        opacity: 0.28;
        pointer-events: none;
        transform: rotate(-8deg) skewX(-9deg);
      }

      .camp-people {
        left: 32%;
        bottom: 8%;
        z-index: 3;
        width: 28%;
        --fire-lit-filter: brightness(0.8) saturate(0.9);
        filter: var(--fire-lit-filter);
      }

      .camp-fire {
        left: 53%;
        bottom: 0;
        z-index: 4;
        width: 21%;
        aspect-ratio: 1 / 1;
        filter: drop-shadow(0 0 18px rgba(255, 134, 48, 0.24));
      }

      .camp-fire-part {
        position: absolute;
        left: 0;
        width: 100%;
        height: auto;
        object-fit: contain;
        pointer-events: none;
        user-select: none;
      }

      .camp-wood {
        bottom: 0;
        z-index: 1;
      }

      .camp-fire-gif {
        position: absolute;
        left: 50%;
        bottom: 30%;
        z-index: 2;
        width: 88%;
        height: auto;
        object-fit: contain;
        pointer-events: none;
        transform: translateX(-50%);
        mix-blend-mode: screen;
        filter: drop-shadow(0 0 16px rgba(255, 143, 46, 0.3));
        user-select: none;
      }

      .dome.is-camp-extinguished .camp-fire {
        filter: none;
      }

      .dome.is-camp-extinguished .camp-fire-gif,
      .dome.is-camp-extinguished .fire-sparks,
      .dome.is-camp-extinguished .fire-reflection,
      .dome.is-camp-extinguished .people-reflection {
        opacity: 0;
      }

      .dome.is-camp-extinguished .fire-reflection {
        animation: none;
      }

      .dome.is-camp-extinguished .camp-car,
      .dome.is-camp-extinguished .camp-people,
      .dome.is-camp-extinguished .camp-dog {
        animation: none;
        filter: brightness(0.38) saturate(0.38) contrast(0.92);
      }

      .dome.is-camp-extinguished .camp-dog .camp-visual {
        animation: none;
      }

      .dome.is-camp-extinguished .camp-wood {
        opacity: 0.82;
        filter: brightness(0.88) saturate(0.78);
      }

      .dome.is-camp-extinguished .cast-shadow {
        animation: none;
        opacity: 0.48;
      }

      .campfire-modal {
        position: fixed;
        inset: 0;
        z-index: 20;
        display: grid;
        place-items: center;
        padding: 24px;
        background: rgba(2, 6, 16, 0.72);
        backdrop-filter: blur(10px);
      }

      .campfire-modal[hidden] {
        display: none;
      }

      .campfire-panel {
        position: relative;
        width: min(420px, calc(100vw - 32px));
        padding: 24px;
        border: 1px solid rgba(255, 202, 121, 0.2);
        border-radius: 8px;
        background:
          radial-gradient(ellipse at 50% 32%, rgba(255, 139, 45, 0.18), transparent 36%),
          linear-gradient(180deg, rgba(16, 23, 39, 0.96), rgba(5, 9, 18, 0.98));
        box-shadow:
          0 28px 80px rgba(0, 0, 0, 0.48),
          inset 0 1px 0 rgba(255, 255, 255, 0.06);
      }

      .campfire-close {
        position: absolute;
        top: 12px;
        right: 12px;
        z-index: 3;
        display: grid;
        width: 34px;
        height: 34px;
        place-items: center;
        border: 1px solid rgba(231, 238, 251, 0.16);
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.04);
        color: rgba(244, 247, 251, 0.82);
        cursor: pointer;
      }

      .campfire-close:hover,
      .campfire-close:focus-visible {
        border-color: rgba(255, 202, 121, 0.36);
        outline: none;
      }

      .campfire-visual {
        position: relative;
        display: grid;
        height: 164px;
        place-items: center;
        margin-bottom: 8px;
        pointer-events: none;
      }

      .campfire-visual::before {
        position: absolute;
        width: 178px;
        height: 96px;
        border-radius: 50%;
        background: radial-gradient(ellipse at 50% 50%, rgba(255, 139, 45, 0.2), transparent 68%);
        filter: blur(14px);
        content: "";
      }

      .campfire-visual img {
        position: relative;
        z-index: 1;
        width: 132px;
        height: auto;
        mix-blend-mode: screen;
      }

      .campfire-modal.is-extinguished .campfire-visual::before {
        background: radial-gradient(ellipse at 50% 50%, rgba(132, 146, 166, 0.08), transparent 68%);
      }

      .campfire-modal.is-extinguished .campfire-visual img {
        mix-blend-mode: normal;
        opacity: 0.86;
        filter: brightness(0.88) saturate(0.78);
      }

      .campfire-title {
        margin: 0;
        font-size: 20px;
        font-weight: 800;
        line-height: 1.25;
        text-align: center;
      }

      .campfire-copy {
        min-height: 24px;
        margin: 10px 0 18px;
        color: rgba(232, 238, 249, 0.68);
        font-size: 13px;
        line-height: 1.7;
        text-align: center;
      }

      .campfire-meter {
        display: grid;
        gap: 8px;
        margin-bottom: 18px;
      }

      .campfire-meter-label {
        display: flex;
        justify-content: space-between;
        color: rgba(244, 247, 251, 0.78);
        font-size: 12px;
        font-weight: 700;
      }

      .campfire-track {
        height: 8px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
      }

      .campfire-fill {
        width: calc(var(--campfire-level, 0) * 1%);
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #f97316, #facc15);
        box-shadow: 0 0 18px rgba(255, 161, 54, 0.42);
        transition: width 220ms ease;
      }

      .campfire-action {
        width: 100%;
        min-height: 44px;
        border: 0;
        border-radius: 8px;
        background: linear-gradient(180deg, #ffd27a, #ff8a2a);
        color: #1f1208;
        cursor: pointer;
        font: inherit;
        font-size: 14px;
        font-weight: 800;
        box-shadow: 0 10px 26px rgba(255, 122, 24, 0.26);
      }

      .campfire-action:hover:not(:disabled),
      .campfire-action:focus-visible:not(:disabled) {
        filter: brightness(1.06);
        outline: none;
      }

      .campfire-action:disabled {
        cursor: not-allowed;
        filter: grayscale(0.45) brightness(0.72);
      }

      .campfire-secondary-action {
        width: 100%;
        min-height: 38px;
        margin-top: 10px;
        border: 1px solid rgba(232, 238, 249, 0.16);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.04);
        color: rgba(232, 238, 249, 0.72);
        cursor: pointer;
        font: inherit;
        font-size: 13px;
        font-weight: 700;
      }

      .campfire-secondary-action:hover:not(:disabled),
      .campfire-secondary-action:focus-visible:not(:disabled) {
        border-color: rgba(255, 202, 121, 0.28);
        color: rgba(244, 247, 251, 0.92);
        outline: none;
      }

      .campfire-secondary-action:disabled {
        cursor: not-allowed;
        opacity: 0.42;
      }

      .campfire-status {
        min-height: 18px;
        margin: 12px 0 0;
        color: rgba(232, 238, 249, 0.52);
        font-size: 12px;
        line-height: 1.5;
        text-align: center;
      }

      .fire-sparks {
        position: absolute;
        left: 63.5%;
        bottom: 31%;
        z-index: 5;
        width: 58px;
        height: 68px;
        pointer-events: none;
        transform: translateX(-50%);
      }

      .fire-sparks span {
        position: absolute;
        bottom: 0;
        left: 50%;
        width: var(--spark-size, 4px);
        height: var(--spark-size, 4px);
        border-radius: 50%;
        background: rgba(255, 196, 93, 0.92);
        box-shadow: 0 0 10px rgba(255, 139, 45, 0.72);
        opacity: 0;
      }

      .fire-sparks .spark-small {
        --spark-size: 2.5px;
        background: rgba(255, 210, 130, 0.82);
        box-shadow: 0 0 7px rgba(255, 139, 45, 0.5);
      }

      .fire-sparks span:nth-child(1) {
        margin-left: -18px;
      }

      .fire-sparks span:nth-child(2) {
        margin-left: -8px;
      }

      .fire-sparks span:nth-child(3) {
        margin-left: 6px;
      }

      .fire-sparks span:nth-child(4) {
        margin-left: 18px;
      }

      .fire-sparks span:nth-child(5) {
        margin-left: 0;
      }

      .fire-sparks span:nth-child(6) {
        margin-left: 13px;
      }

      .camp-dog {
        right: 8%;
        bottom: 9%;
        z-index: 2;
        width: 16%;
        cursor: url("/camp/cursor_dog_hover.png") 18 20, pointer;
        --fire-lit-filter: brightness(0.9) saturate(0.86);
        filter: var(--fire-lit-filter);
      }

      .camp-dog .camp-visual {
        transform-origin: 50% 92%;
        animation: dog-breathe 5.2s ease-in-out infinite;
      }

      .footer {
        padding: 0;
      }

      @media (max-width: 760px) {
        .shell {
          padding: 0;
        }

        .footer {
          align-items: flex-start;
          flex-direction: column;
        }

        .sky {
          min-height: 100vh;
          padding-top: 0;
        }

        .dome {
          min-height: 100vh;
          border-radius: 0;
        }

        .intro {
          top: 28px;
          left: 20px;
        }

        .planet {
          --planet-size: calc(var(--size) * 0.72px);
        }

        #games {
          left: 27%;
          top: 42%;
        }

        #travel {
          left: 73%;
          top: 37%;
        }

        #projects {
          --planet-size: calc(var(--size) * 0.55px);
          left: 56%;
          top: 56%;
        }

        .planet-label {
          max-width: 112px;
          white-space: normal;
        }

        .info-card {
          width: min(270px, calc(100% - 28px));
        }
      }

      @media (min-width: 761px) {
        .planet {
          --planet-size: calc(var(--size) * 1px);
        }
      }

      @media (prefers-reduced-motion: no-preference) {
        body::before {
          animation: stars-drift 38s linear infinite;
        }

        .planet {
          animation: planet-float 7s ease-in-out infinite;
          animation-delay: calc(var(--x) * -80ms);
        }

        .fire-sparks span {
          animation: spark-rise-bright 3.6s ease-out infinite;
        }

        .fire-sparks span:nth-child(2) {
          animation-delay: 0.18s;
        }

        .fire-sparks span:nth-child(3) {
          animation-delay: 0.36s;
        }

        .fire-sparks span:nth-child(4) {
          animation-delay: 0.54s;
        }

        .fire-sparks .spark-small {
          animation-name: spark-rise-dim;
        }

        .fire-sparks .spark-small:nth-child(5) {
          animation-delay: 0.12s;
        }

        .fire-sparks .spark-small:nth-child(6) {
          animation-delay: 0.46s;
        }

        .camp-car,
        .camp-people,
        .camp-dog {
          animation: firelight-shimmer 3.6s ease-in-out infinite;
        }

        .cast-shadow {
          animation: cast-shadow-shimmer 3.6s ease-in-out infinite;
        }

        .people-reflection {
          animation: reflection-shimmer 3.6s ease-in-out infinite;
        }

        .fire-reflection {
          animation: ground-firelight 3.6s ease-in-out infinite;
        }
      }

      @keyframes stars-drift {
        to {
          background-position:
            190px 190px,
            290px 340px,
            440px 370px;
        }
      }

      @keyframes planet-float {
        0%,
        100% {
          margin-top: -5px;
        }

        50% {
          margin-top: 7px;
        }
      }

      @keyframes spark-rise-bright {
        0% {
          opacity: 0;
          transform: translate3d(0, 0, 0) scale(0.55);
        }

        28% {
          opacity: 0.92;
          transform: translate3d(0, -12px, 0) scale(0.9);
        }

        62% {
          opacity: 0.48;
          transform: translate3d(calc(var(--spark-drift, 8px) * 0.58), -42px, 0) scale(0.42);
        }

        100% {
          opacity: 0;
          transform: translate3d(var(--spark-drift, 8px), -66px, 0) scale(0.16);
        }
      }

      @keyframes spark-rise-dim {
        0% {
          opacity: 0.62;
          transform: translate3d(0, 0, 0) scale(0.82);
        }

        22% {
          opacity: 0.38;
          transform: translate3d(calc(var(--spark-drift, 8px) * 0.35), -20px, 0) scale(0.52);
        }

        36%,
        72% {
          opacity: 0;
        }

        82% {
          opacity: 0.5;
          transform: translate3d(0, 0, 0) scale(0.72);
        }

        100% {
          opacity: 0;
          transform: translate3d(var(--spark-drift, 8px), -34px, 0) scale(0.28);
        }
      }

      @keyframes firelight-shimmer {
        0%,
        100% {
          filter: var(--fire-lit-filter) drop-shadow(0 0 0 rgba(255, 134, 48, 0));
        }

        22% {
          filter: brightness(0.88) saturate(0.92) drop-shadow(0 0 2px rgba(255, 139, 45, 0.06));
        }

        42% {
          filter: brightness(1.12) saturate(1.12) drop-shadow(0 0 13px rgba(255, 150, 54, 0.22));
        }

        58% {
          filter: brightness(1.04) saturate(1.06) drop-shadow(0 0 8px rgba(255, 139, 45, 0.16));
        }

        76% {
          filter: brightness(0.9) saturate(0.94) drop-shadow(0 0 3px rgba(255, 139, 45, 0.08));
        }
      }

      @keyframes lighthouse-glow {
        0%,
        100% {
          opacity: 0.34;
          transform: scale(0.992);
        }

        48% {
          opacity: 0.43;
          transform: scale(1.006);
        }

        64% {
          opacity: 0.38;
          transform: scale(1);
        }
      }

      @keyframes dog-breathe {
        0%,
        100% {
          transform: scaleY(1);
        }

        50% {
          transform: scaleY(1.03);
        }
      }

      @keyframes cast-shadow-shimmer {
        0%,
        100% {
          opacity: 0.62;
          filter: blur(7px);
        }

        42% {
          opacity: 0.76;
          filter: blur(8px);
        }

        76% {
          opacity: 0.5;
          filter: blur(6px);
        }
      }

      @keyframes reflection-shimmer {
        0%,
        100% {
          opacity: 0.22;
          filter: blur(3.5px);
        }

        42% {
          opacity: 0.38;
          filter: blur(4px);
        }

        76% {
          opacity: 0.18;
          filter: blur(3px);
        }
      }

      @keyframes ground-firelight {
        0%,
        100% {
          opacity: 0.42;
          transform: translateX(-50%) scale(0.9, 0.84);
        }

        22% {
          opacity: 0.5;
          transform: translateX(-50%) scale(0.96, 0.9);
        }

        42% {
          opacity: 0.96;
          transform: translateX(-50%) scale(1.12, 1.08);
        }

        58% {
          opacity: 0.76;
          transform: translateX(-50%) scale(1.04, 1);
        }

        76% {
          opacity: 0.48;
          transform: translateX(-50%) scale(0.94, 0.88);
        }
      }
    </style>
  </head>

