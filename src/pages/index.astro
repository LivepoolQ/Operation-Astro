    <div class="campfire-modal" data-campfire-modal hidden role="dialog" aria-modal="true" aria-labelledby="campfire-title">
      <div class="campfire-panel">
        <button class="campfire-close" type="button" data-campfire-close aria-label="Close campfire">×</button>
        <div class="campfire-visual" aria-hidden="true">
          <img src="/camp/fire.gif" alt="" loading="lazy" decoding="async" draggable="false" />
        </div>
        <h2 class="campfire-title" id="campfire-title">Campfire</h2>
        <p class="campfire-copy" data-campfire-copy>Checking the fire...</p>
        <div class="campfire-meter" aria-hidden="true">
          <div class="campfire-meter-label">
            <span data-campfire-wood>0 logs</span>
            <span>30 max</span>
          </div>
          <div class="campfire-track">
            <div class="campfire-fill" data-campfire-fill></div>
          </div>
        </div>
        <button class="campfire-action" type="button" data-campfire-add>Add one log</button>
        <button class="campfire-secondary-action" type="button" data-campfire-extinguish>Extinguish fire</button>
        <p class="campfire-status" data-campfire-status aria-live="polite"></p>
      </div>
    </div>

    <script>
      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }
      window.scrollTo(0, 0);

      const planets = Array.from(document.querySelectorAll(".planet"));
      const title = document.querySelector("[data-info-title]");
      const orbit = document.querySelector("[data-info-orbit]");
      const description = document.querySelector("[data-info-description]");
      const card = document.querySelector(".info-card");
      const dome = document.querySelector(".dome");

      const activatePlanet = (planet) => {
        planets.forEach((item) => item.classList.toggle("is-active", item === planet));
        if (title) title.textContent = planet.dataset.title || "";
        if (orbit) orbit.textContent = planet.dataset.orbit || "";
        if (description) description.textContent = planet.dataset.description || "";
        if (card) {
          const dome = planet.closest(".dome");
          const domeRect = dome.getBoundingClientRect();
          const planetRect = planet.getBoundingClientRect();
          const cardWidth = Math.min(292, domeRect.width - 36);
          const cardHeight = card.offsetHeight;
          const planetCenter = planetRect.left - domeRect.left + planetRect.width / 2;
          let left = planetCenter - cardWidth / 2;
          let top = planetRect.top - domeRect.top - cardHeight - 22;

          left = Math.min(Math.max(18, left), domeRect.width - cardWidth - 18);

          if (top < 18) {
            top = planetRect.bottom - domeRect.top + 22;
          }

          card.style.left = `${Math.max(18, left)}px`;
          card.style.top = `${Math.max(18, top)}px`;
          card.classList.add("is-visible");
          card.setAttribute("aria-hidden", "false");
        }
      };

      const hideCard = () => {
        planets.forEach((item) => item.classList.remove("is-active"));
        if (card) {
          card.classList.remove("is-visible");
          card.setAttribute("aria-hidden", "true");
        }
      };

      planets.forEach((planet) => {
        planet.addEventListener("mouseenter", () => activatePlanet(planet));
        planet.addEventListener("mouseleave", hideCard);
        planet.addEventListener("focus", () => activatePlanet(planet));
        planet.addEventListener("blur", hideCard);
      });


      const campItems = Array.from(document.querySelectorAll("[data-camp-item]"));

      const emitCampEvent = (name, item, extra = {}) => {
        const detail = {
          id: item.dataset.campItem || "",
          label: item.dataset.campLabel || "",
          element: item,
          ...extra,
        };
        window.dispatchEvent(new CustomEvent(`camp:${name}`, { detail }));
      };

      campItems.forEach((item) => {
        item.addEventListener("mouseenter", () => {
          item.classList.add("is-camp-hovered");
          emitCampEvent("hover", item);
        });

        item.addEventListener("mouseleave", () => {
          item.classList.remove("is-camp-hovered");
          emitCampEvent("leave", item);
        });

        item.addEventListener("focus", () => {
          item.classList.add("is-camp-hovered");
          emitCampEvent("focus", item);
        });

        item.addEventListener("blur", () => {
          item.classList.remove("is-camp-hovered", "is-camp-active");
          emitCampEvent("blur", item);
        });

        item.addEventListener("click", () => {
          campItems.forEach((other) => {
            if (other !== item) other.classList.remove("is-camp-active");
          });
          item.classList.toggle("is-camp-active");
          emitCampEvent("click", item, {
            active: item.classList.contains("is-camp-active"),
          });
        });
      });

      const DAY_MS = 24 * 60 * 60 * 1000;
      const MAX_WOOD = 30;
      const LOCAL_CAMPFIRE_KEY = "operation-astro-campfire";
      const CAMP_WOOD_SRC = "/camp/wood.png";
      const CAMP_FIRE_SRC = "/camp/fire.gif";
      const CAMP_SMOKE_SRC = "/camp/smoke.gif";
      const campfireModal = document.querySelector("[data-campfire-modal]");
      const campfireClose = document.querySelector("[data-campfire-close]");
      const campfireAdd = document.querySelector("[data-campfire-add]");
      const campfireExtinguish = document.querySelector("[data-campfire-extinguish]");
      const campfireCopy = document.querySelector("[data-campfire-copy]");
      const campfireWood = document.querySelector("[data-campfire-wood]");
      const campfireFill = document.querySelector("[data-campfire-fill]");
      const campfireStatus = document.querySelector("[data-campfire-status]");
      const campWoodImage = document.querySelector(".camp-wood");
      const campfireVisualImage = document.querySelector(".campfire-visual img");
      let campfireSource = "api";

      const getCampfireSnapshot = (state = {}) => {
        const now = Date.now();
        const burnUntil = Number.isFinite(state.burnUntil) ? state.burnUntil : 0;
        const remainingMs = Math.max(0, burnUntil - now);
        const woodCount = Math.min(MAX_WOOD, Math.ceil(remainingMs / DAY_MS));
        return {
          burnUntil,
          remainingMs,
          woodCount,
          isFull: woodCount >= MAX_WOOD,
        };
      };

      const formatRemaining = (remainingMs) => {
        if (remainingMs <= 0) return "The fire is waiting for its first log.";
        const days = Math.floor(remainingMs / DAY_MS);
        const hours = Math.ceil((remainingMs % DAY_MS) / (60 * 60 * 1000));
        if (days <= 0) return `${hours} hour${hours === 1 ? "" : "s"} of warmth left.`;
        if (hours >= 24) return `${days + 1} day${days + 1 === 1 ? "" : "s"} of warmth left.`;
        return `${days} day${days === 1 ? "" : "s"} ${hours} hour${hours === 1 ? "" : "s"} of warmth left.`;
      };

      const readLocalCampfire = () => {
        try {
          return getCampfireSnapshot(JSON.parse(localStorage.getItem(LOCAL_CAMPFIRE_KEY) || "{}"));
        } catch {
          return getCampfireSnapshot();
        }
      };

      const writeLocalCampfire = (state) => {
        localStorage.setItem(LOCAL_CAMPFIRE_KEY, JSON.stringify({ burnUntil: state.burnUntil }));
      };

      const applyCampfireScene = (snapshot) => {
        const isExtinguished = snapshot.woodCount === 0 && snapshot.remainingMs <= 0;
        dome?.classList.toggle("is-camp-extinguished", isExtinguished);
        campfireModal?.classList.toggle("is-extinguished", isExtinguished);
        if (campWoodImage) campWoodImage.src = isExtinguished ? CAMP_SMOKE_SRC : CAMP_WOOD_SRC;
        if (campfireVisualImage) campfireVisualImage.src = isExtinguished ? CAMP_SMOKE_SRC : CAMP_FIRE_SRC;
      };

      const renderCampfire = (state, status = "") => {
        const snapshot = getCampfireSnapshot(state);
        applyCampfireScene(snapshot);
        if (campfireCopy) campfireCopy.textContent = formatRemaining(snapshot.remainingMs);
        if (campfireWood) campfireWood.textContent = `${snapshot.woodCount} log${snapshot.woodCount === 1 ? "" : "s"}`;
        if (campfireFill) campfireFill.style.setProperty("--campfire-level", `${Math.round((snapshot.woodCount / MAX_WOOD) * 100)}`);
        if (campfireAdd) {
          campfireAdd.disabled = snapshot.isFull;
          campfireAdd.textContent = snapshot.isFull ? "The fire is full" : "Add one log";
        }
        if (campfireExtinguish) {
          campfireExtinguish.disabled = snapshot.woodCount === 0 && snapshot.remainingMs <= 0;
        }
        if (campfireStatus) campfireStatus.textContent = status;
      };

      const fetchCampfire = async () => {
        try {
          const response = await fetch("/api/campfire", {
            headers: { Accept: "application/json" },
            cache: "no-store",
          });
          if (!response.ok) throw new Error("Campfire API unavailable");
          campfireSource = "api";
          const state = await response.json();
          renderCampfire(state);
        } catch {
          campfireSource = "local";
          renderCampfire(readLocalCampfire(), "Local preview. Cloudflare KV will keep the shared fire online.");
        }
      };

      const addCampfireWood = async () => {
        if (!campfireAdd) return;
        campfireAdd.disabled = true;
        if (campfireStatus) campfireStatus.textContent = "Adding a log...";

        if (campfireSource === "local") {
          const current = readLocalCampfire();
          const base = Math.max(Date.now(), current.burnUntil);
          const next = getCampfireSnapshot({ burnUntil: Math.min(Date.now() + MAX_WOOD * DAY_MS, base + DAY_MS) });
          writeLocalCampfire(next);
          renderCampfire(next, "Saved in this browser for local preview.");
          return;
        }

        try {
          const response = await fetch("/api/campfire/add-wood", {
            method: "POST",
            headers: { Accept: "application/json" },
          });
          const state = await response.json();
          if (!response.ok) throw new Error(state.error || "Could not add wood");
          renderCampfire(state, "One log added.");
        } catch {
          campfireSource = "local";
          const current = readLocalCampfire();
          const base = Math.max(Date.now(), current.burnUntil);
          const next = getCampfireSnapshot({ burnUntil: Math.min(Date.now() + MAX_WOOD * DAY_MS, base + DAY_MS) });
          writeLocalCampfire(next);
          renderCampfire(next, "Using local preview until the Cloudflare KV binding is ready.");
        }
      };

      const extinguishCampfire = async () => {
        if (!campfireExtinguish) return;
        campfireExtinguish.disabled = true;
        if (campfireStatus) campfireStatus.textContent = "Letting the fire go dark...";

        const next = getCampfireSnapshot({ burnUntil: 0, updatedAt: Date.now() });

        if (campfireSource === "local") {
          writeLocalCampfire(next);
          renderCampfire(next, "The campfire is out in local preview.");
          return;
        }

        try {
          const response = await fetch("/api/campfire/extinguish", {
            method: "POST",
            headers: { Accept: "application/json" },
          });
          const state = await response.json();
          if (!response.ok) throw new Error(state.error || "Could not extinguish fire");
          renderCampfire(state, "The campfire is out.");
        } catch {
          campfireSource = "local";
          writeLocalCampfire(next);
          renderCampfire(next, "Using local preview until the Cloudflare KV binding is ready.");
        }
      };

      const openCampfire = () => {
        if (!campfireModal) return;
        campfireModal.hidden = false;
        fetchCampfire();
        campfireAdd?.focus();
      };

      const closeCampfire = () => {
        if (campfireModal) campfireModal.hidden = true;
      };

      window.addEventListener("camp:click", (event) => {
        if (event.detail?.id === "fire") openCampfire();
      });

      campfireAdd?.addEventListener("click", addCampfireWood);
      campfireExtinguish?.addEventListener("click", extinguishCampfire);
      campfireClose?.addEventListener("click", closeCampfire);
      campfireModal?.addEventListener("click", (event) => {
        if (event.target === campfireModal) closeCampfire();
      });
      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeCampfire();
      });

      fetchCampfire();

      const updateCampPerspective = () => {
        if (!dome) return;
        const maxLift = Math.min(720, Math.max(420, window.innerHeight * 0.6));
        const travel = Math.max(1, window.innerHeight * 1.35);
        const progress = Math.min(1, Math.max(0, window.scrollY / travel));
        const eased = 1 - Math.pow(1 - progress, 2);
        const campLift = Math.round(eased * maxLift);
        dome.style.setProperty("--camp-lift", `${campLift}px`);
        dome.style.setProperty("--ridge-far-lift", `${Math.round(campLift * 1)}px`);
        dome.style.setProperty("--ridge-middle-lift", `${Math.round(campLift * 1.2)}px`);
        dome.style.setProperty("--forest-far-lift", `${Math.round(campLift * 1.4)}px`);
        dome.style.setProperty("--planet-depth", `${(1 - eased * 0.4).toFixed(3)}`);
      };

      let scrollFrame = 0;
      const requestCampPerspective = () => {
        if (scrollFrame) return;
        scrollFrame = window.requestAnimationFrame(() => {
          scrollFrame = 0;
          updateCampPerspective();
        });
      };

      window.addEventListener("scroll", requestCampPerspective, { passive: true });
      window.addEventListener("resize", requestCampPerspective);
      updateCampPerspective();
    </script>
  </body>
</html>
